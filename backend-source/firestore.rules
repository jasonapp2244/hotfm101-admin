rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Check if the requesting user has an admin-level role in the users collection.
    // Uses .lower() so role values are compared case-insensitively.
    function isAdmin() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower()
             in ['super admin', 'admin', 'editor', 'staff'];
    }

    // Users collection — admins can list all; any auth user can read their own doc (mobile self-profile)
    match /users/{userId} {
      allow get:   if isAuth() && (isAdmin() || request.auth.uid == userId);
      allow list:  if isAdmin();
      allow write: if isAdmin();
    }

    // Articles - public read, admin write
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contests - public read, admin write
    match /contests/{contestId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events - public read, admin write
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Shoutouts - public read, admin manages all
    match /shoutouts/{shoutoutId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications - public read, admin write
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ads - public read, admin write
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Broadcasts - public read, admin write
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ad Analytics - admin only
    match /adAnalytics/{adId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Activity Log - admin only
    match /activityLog/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Contest entries
    match /contestEntries/{entryId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Event RSVPs
    match /eventRsvps/{rsvpId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Shoutout submissions from mobile users
    match /shoutoutSubmissions/{subId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Ad analytics events logged by mobile app — require auth to prevent unauthenticated spam/abuse
    match /adEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    // FCM tokens — admin browser registers its own push token; Cloud Functions read via admin SDK
    match /fcmTokens/{token} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // Email queue — admin can create & read; Cloud Function (admin SDK) writes status back
    match /emailQueue/{emailId} {
      allow create: if isAdmin();
      allow read:   if isAdmin();
      allow update, delete: if false; // only Cloud Function updates via admin SDK
    }

    // Settings (Privacy Policy, etc.) - public read, admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();

      match /versions/{versionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
  }
}
