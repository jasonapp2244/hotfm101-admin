# Admin panel account passwords — used by create-admin-users.js and reset-passwords.js
#
# Copy this file to .env (which is gitignored) and fill in real values:
#   cp .env.example .env
#
# Then run either script with:
#   node --env-file=.env create-admin-users.js
#   node --env-file=.env reset-passwords.js
#
# Firebase requires a minimum of 6 characters. Use strong, unique values —
# these grant write access to live Firestore and can trigger push
# notifications to every listener device.

SUPERADMIN_PASSWORD=
ADMIN_PASSWORD=
EDITOR_PASSWORD=
STAFF_PASSWORD=
